#!/usr/bin/env bash
# Wolvrix Playground Environment Configuration Template
# Usage:
#   1. Copy this file to env.sh: cp env.sh.template env.sh
#   2. Edit env.sh and set the paths according to your environment
#   3. Source the file: source env.sh
# Note: env.sh is added to .gitignore and will not be tracked by git

# ============================== USER EDITABLE START ==============================
# You can safely edit variables in this section.

#------------------------------------------------------------------------------
# RISC-V Toolchain Configuration (Required for OpenC910 tests)
#------------------------------------------------------------------------------
# TOOL_EXTENSION: Path to the RISC-V GCC toolchain bin directory
# Used to compile OpenC910 test cases (e.g., coremark, dhrystone, etc.)
# Download: https://www.xrvm.com/community/download?id=4058840482644627456
#
# Example paths (modify according to your actual installation):
# export TOOL_EXTENSION="/download/Xuantie-900-gcc-elf-newlib-x86_64-V2.0.3/bin"
# export TOOL_EXTENSION="/opt/riscv/bin"
# export TOOL_EXTENSION="$HOME/tools/riscv64-unknown-elf/bin"
export TOOL_EXTENSION="/download/Xuantie-900-gcc-elf-newlib-x86_64-V2.0.3/bin"

#------------------------------------------------------------------------------
# Verilator Configuration (Optional)
#------------------------------------------------------------------------------
# VERILATOR: Path to the verilator executable
# If not set, defaults to "verilator" (expects it in PATH)
# Only needed if verilator is not in your PATH or you want to use a specific version
#
export VERILATOR="verilator"
# export VERILATOR="/usr/local/bin/verilator"
# export VERILATOR="/opt/verilator/bin/verilator"

#------------------------------------------------------------------------------
# XiangShan Configuration
#------------------------------------------------------------------------------
# NOOP_HOME: Path to the XiangShan RTL directory
# Used for XiangShan processor tests
# Compute absolute path based on this script's location
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export NOOP_HOME="${SCRIPT_DIR}/testcase/xiangshan"

# =============================== USER EDITABLE END ===============================

# ============================== DO NOT TOUCH START ===============================
# Python environment bootstrap for wolvrix development.
# This section was merged from setup_pyvenv.sh.

if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    _SETUP_PYVENV_SOURCED=1
    _SETUP_PYVENV_RESTORE_OPTS="$(set +o)"
    set -uo pipefail
else
    _SETUP_PYVENV_SOURCED=0
    set -euo pipefail
fi

die() {
    local status="$1"
    if [[ "${_SETUP_PYVENV_SOURCED}" == "1" ]]; then
        eval "${_SETUP_PYVENV_RESTORE_OPTS}"
        unset _SETUP_PYVENV_RESTORE_OPTS
        return "${status}"
    fi
    exit "${status}"
}

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="${ROOT_DIR}/.venv"

echo "[PY] Creating virtual environment at ${VENV_DIR}"
python3 -m venv "${VENV_DIR}" || die $?

echo "[PY] Installing scikit-build-core into ${VENV_DIR}"
"${VENV_DIR}/bin/python" -m pip install scikit-build-core || die $?

# Guard flag: indicates env.sh has been sourced and initialized successfully.
export WOLF_ENV_SOURCED=1

if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # Sourced: activate in the caller's current shell.
    # shellcheck disable=SC1091
    source "${VENV_DIR}/bin/activate" || die $?
    eval "${_SETUP_PYVENV_RESTORE_OPTS}"
    unset _SETUP_PYVENV_RESTORE_OPTS
    echo "[PY] Activated ${VENV_DIR} in the current shell"
else
    # Executed: activate in this process and hand off to a new interactive shell.
    # shellcheck disable=SC1091
    source "${VENV_DIR}/bin/activate" || die $?
    echo "[PY] Starting a new shell with ${VENV_DIR} activated"
    exec "${SHELL:-/bin/bash}" -i
fi

# =============================== DO NOT TOUCH END ================================
